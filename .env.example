# ---- Hugo environment (PRD 5.21) -------------------------------------------
# Copy to .env.local and fill in. NEVER commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Convex (set automatically by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Vercel AI Gateway — server only, never exposed to the browser.
# Required locally for realtime voice + text chat. Vercel production can use OIDC.
# Get a local key at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Auth / roles
DEFAULT_ADMIN_EMAIL=solsymbaiex@gmail.com

# Models + voice (admin-configurable at runtime via Settings)
DEFAULT_REALTIME_MODEL=openai/gpt-realtime-2
DEFAULT_TEXT_MODEL=minimax/minimax-m2.7
DEFAULT_VOICE=alloy

# Product flags + limits
ENABLE_GUEST_PREVIEW=false
DAILY_VOICE_MINUTES_LIMIT=30
DAILY_TEXT_MESSAGES_LIMIT=200

# Observability (optional): set to "true" to record prompts/outputs for admin
# debugging only. Off by default (PRD 5.17).
HUGO_RECORD_PROMPTS=false

# ---- Set in the Convex deployment env (not here), via `npx convex env set` ---
# CONVEX_SITE_URL=http://localhost:3000
# JWT_PRIVATE_KEY / JWKS        # generated by `npx @convex-dev/auth`
# Sign in with Vercel (optional OAuth login). Register an App under your Vercel
# team (Settings -> Apps), enable openid/email/profile, and register the callback
# URL <CONVEX_SITE_URL>/api/auth/callback/vercel. Then set on Convex (dev + --prod):
# AUTH_VERCEL_ID=<client-id>
# AUTH_VERCEL_SECRET=<client-secret>
# The button auto-appears once these are set; see convex/auth.ts for details.

# BYOK: server secret used to AES-GCM-encrypt per-user gateway keys at rest.
# Generate: node -e "console.log(crypto.randomBytes(32).toString(\"hex\"))"
KEY_ENCRYPTION_SECRET=

# TinyFish Search API (server-only, admin default). Non-admins BYOK their own
# key in Settings; this is only the admin/server fallback. Get one at
# https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=
